{
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(du *)",
      "Bash(df *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(*credentials*)",
      "Read(*secret*)",
      "Bash(env *)",
      "Bash(cat .env*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(tail .env*)",
      "Bash(head .env*)",
      "Bash(grep .env*)"
    ],
    "ask": ["Bash(curl:*)"],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$FILE_PATH\" == *.go ]]; then go fmt \"$FILE_PATH\"; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/lotarola/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
